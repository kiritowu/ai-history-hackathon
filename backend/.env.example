# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.1

# OCR provider
OCR_BACKEND=paddle_vl_server
PADDLEOCR_VL_SERVER_URL=http://127.0.0.1:8111/
PADDLEOCR_VL_BACKEND=mlx-vlm-server
PADDLEOCR_VL_API_MODEL_NAME=PaddlePaddle/PaddleOCR-VL-1.5
VLM_OCR_BASE_URL=
VLM_OCR_MODEL=PaddlePaddle/PaddleOCR-VL
VLM_OCR_API_KEY=EMPTY
VLM_OCR_TASK_PROMPT=OCR:
VLM_OCR_TIMEOUT_SECONDS=600
VLM_OCR_PDF_DPI=200

# Embeddings (always external to Weaviate)
EMBEDDING_BACKEND=openai_compatible
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=

# Weaviate Cloud
WEAVIATE_COLLECTION=DocumentChunk
WEAVIATE_URL=
WEAVIATE_API_KEY=

# GCP
GCP_PROJECT=

# RAG defaults
RAG_TOP_K=4
CHUNK_SIZE=700
CHUNK_OVERLAP=120
PDF_PAGE_BATCH_SIZE=10
